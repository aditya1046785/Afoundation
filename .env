# ------------ DATABASE URL OPTIONS ------------
# Option 1: Local Storage (Active)
# Make sure you have a local PostgreSQL server running with these credentials and database created.
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/nirashray_db"

# Option 2: External Live Storage (Supabase)
# Uncomment the following line and replace with your actual Supabase connection string to use live storage.
# DATABASE_URL="postgresql://postgres.[your-project-ref]:[your-password]@aws-0-[region].pooler.supabase.com:6543/postgres"
# ----------------------------------------------
NEXTAUTH_SECRET="generate-a-random-secret-here-using-openssl-rand-base64-32"
NEXTAUTH_URL="http://localhost:3000"
RAZORPAY_KEY_ID="rzp_test_xxxxx"
RAZORPAY_KEY_SECRET="xxxxx"
NEXT_PUBLIC_RAZORPAY_KEY_ID="rzp_test_xxxxx"
RESEND_API_KEY="re_xxxxx"
NEXT_PUBLIC_APP_URL="http://localhost:3000"
CLOUDINARY_CLOUD_NAME="xxxxx"
CLOUDINARY_API_KEY="xxxxx"
CLOUDINARY_API_SECRET="xxxxx"
